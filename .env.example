# Public client config (safe to expose)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
EXPO_PUBLIC_GEMINI_PROXY_URL_DEV=http://localhost:3000/api/gemini-recommend
EXPO_PUBLIC_GEMINI_PROXY_URL_PROD=https://your-vercel-domain.vercel.app/api/gemini-recommend
EXPO_PUBLIC_GEMINI_PROXY_URL=

EXPO_PUBLIC_SPOTIFY_CATALOG_TIMEOUT_PRIMARY_MS=14000
EXPO_PUBLIC_SPOTIFY_CATALOG_TIMEOUT_SECONDARY_MS=11000
EXPO_PUBLIC_SPOTIFY_CATALOG_TIMEOUT_RESCUE_MS=12000
EXPO_PUBLIC_SPOTIFY_CATALOG_TIMEOUT_LAST_RESORT_MS=16000
EXPO_PUBLIC_PLAYLIST_GENERATION_TIMEOUT_MS=90000
EXPO_PUBLIC_GEMINI_PIPELINE_BUDGET_MS=65000
EXPO_PUBLIC_SPOTIFY_ENABLE_METADATA_ENRICH=true

EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

EXPO_PUBLIC_WEB_BASE_URL_DEV=https://your-vercel-domain.vercel.app
EXPO_PUBLIC_WEB_BASE_URL_PROD=https://your-vercel-domain.vercel.app
EXPO_PUBLIC_SPOTIFY_WEB_REDIRECT_URI_DEV=https://your-vercel-domain.vercel.app/auth/spotify-login
EXPO_PUBLIC_SPOTIFY_WEB_REDIRECT_URI_PROD=https://your-vercel-domain.vercel.app/auth/spotify-login

# Server-only secrets (never prefix with EXPO_PUBLIC_)
GEMINI_API_KEY=your_server_side_gemini_key
GEMINI_PROXY_ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app
GEMINI_PROXY_RATE_LIMIT_PER_MINUTE=20
GEMINI_PROXY_MAX_RPD=180
