{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npx expo export --platform web && mkdir -p dist/_expo/static/js/web && cp node_modules/canvaskit-wasm/bin/full/canvaskit.wasm dist/_expo/static/js/web/canvaskit.wasm",
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/auth/spotify-login", "dest": "/auth/spotify-login.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
